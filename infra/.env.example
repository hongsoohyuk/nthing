# ===== Database =====
DB_NAME=onebite
DB_USERNAME=onebite
DB_PASSWORD=change-me-to-secure-password

# ===== JWT =====
JWT_SECRET=change-me-to-random-string-at-least-32-bytes
JWT_EXPIRATION=86400000

# ===== Kakao OAuth =====
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_REDIRECT_URI=https://your-domain.com/api/auth/callback/kakao

# ===== Naver OAuth =====
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/callback/google

# ===== Apple Sign In =====
APPLE_CLIENT_ID=your-apple-client-id

# ===== AWS S3 (uploads) =====
# AWS_REGION 와 S3_BUCKET 는 Terraform 출력값으로 채움:
#   cd infra/terraform && terraform output uploads_bucket_name
#   cd infra/terraform && terraform output -raw uploads_public_url_base
AWS_REGION=ap-northeast-2
S3_BUCKET=onebite-uploads
S3_PUBLIC_URL_BASE=https://onebite-uploads.s3.ap-northeast-2.amazonaws.com
S3_PRESIGN_EXPIRY=300
